# ============================================================
# AgentGenie — Environment Variables
# ============================================================
# Copy to .env for local development.
# In production (Render), set these via the dashboard or render.yaml.
# ============================================================

# --- Core ---
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# --- Database ---
# Local: SQLite (default)
# DATABASE_URL=sqlite:///dev.db
# Production: PostgreSQL (set by Render automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/agentgenie

# --- Redis / Celery ---
# Required for async agent provisioning and webhook processing.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Platform ---
PLATFORM_NAME=AgentGenie
PLATFORM_DOMAIN=localhost:5000

# --- Security ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Retell AI ---
RETELL_API_KEY=key_...
RETELL_WEBHOOK_SECRET=

# --- OpenAI (Agent Config Generation) ---
# Used by the Brain microservice (there is no in-process fallback).
OPENAI_API_KEY_CUSTOM=sk-...

# --- OpenAI Brain Microservice ---
# URL of the separate FastAPI service. Defaults to http://localhost:8100
# In production on Render, set to the internal service URL.
OPENAI_BRAIN_URL=http://localhost:8100

# --- Notification Provider ---
# Options: gmail_smtp (default), sendgrid (future)
NOTIFICATION_EMAIL_PROVIDER=gmail_smtp

# --- Gmail SMTP (Default Notification Provider) ---
# Use a Gmail App Password (not your regular password).
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=your-email@gmail.com
GMAIL_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_SMTP_FROM=noreply@yourdomain.com
GMAIL_SMTP_FROM_NAME=AgentGenie

# --- Flask-Mail (legacy, used for password resets if Gmail SMTP not configured) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# --- SendGrid (Optional alternative email provider) ---
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AgentGenie

# --- Twilio (SMS — future) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Google Calendar (OAuth — optional) ---
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/app/integrations/google-calendar/callback

# --- Feature Flags ---
# Set to 'true' to enable deferred features. All default to false.
FEATURE_PARTNER_PROGRAM=false
FEATURE_DFY=false
FEATURE_CAMPAIGNS=false
