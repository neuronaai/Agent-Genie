# ============================================================
# AgentGenie — Celery Worker Dockerfile
# ============================================================
# Used by Render for the background worker service.
# ============================================================

FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    antiword \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home appuser
WORKDIR /home/appuser/app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

COPY . .

RUN chown -R appuser:appuser /home/appuser/app

USER appuser

# Celery worker command (--beat embeds the periodic task scheduler)
CMD ["celery", "-A", "app.celery_app:celery_app", "worker", "--beat", "--loglevel=info", "--concurrency=2", "--max-tasks-per-child=100"]
